# Common
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require

# Vercel API -> Worker
WORKER_BASE_URL=https://your-worker-xxxxx-uc.a.run.app
WORKER_SHARED_SECRET=change-me
CRON_SHARED_SECRET=change-me-optional

# Worker -> YouTube API
YOUTUBE_API_KEY=your-youtube-api-key
