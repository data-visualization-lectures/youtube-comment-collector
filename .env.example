YOUTUBE_MAX_COMMENT_PAGES=10
YOUTUBE_MAX_VIDEOS_PER_SCAN=25
COMMENT_SCAN_VIDEO_LIMIT_PER_CHANNEL=30

# Worker -> LLM
LLM_PROVIDER=heuristic
LLM_API_BASE_URL=https://api.openai.com/v1
